{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "UnifiedItem",
    "type": "object",
    "required": [
        "meta",
        "intent",
        "payload"
    ],
    "additionalProperties": false,
    "properties": {
        "meta": {
            "type": "object",
            "required": [
                "schema_version",
                "created_at"
            ],
            "properties": {
                "schema_version": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "additionalProperties": false
        },
        "intent": {
            "type": "string",
            "description": "Normalized user intent label"
        },
        "payload": {
            "type": "object",
            "description": "Semantic normalized content",
            "additionalProperties": true
        }
    }
}